# ================================================
# HOSTPILOT — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ================================================

# --- SERVEUR ---
PORT=3000
NODE_ENV=development
API_SECRET=your-strong-secret-key-here

# --- SUPABASE ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- STRIPE (Carte bancaire) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- PAYPAL ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
# Pour la prod: PAYPAL_MODE=live

# --- ORANGE MONEY (API Sénégal) ---
ORANGE_MONEY_CLIENT_ID=your-orange-money-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-money-client-secret
ORANGE_MONEY_MERCHANT_KEY=your-merchant-key
# Endpoint sandbox: https://api.orange.com/orange-money-webpay/dev/v1
# Endpoint prod:    https://api.orange.com/orange-money-webpay/sn/v1
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1

# --- WAVE (API Sénégal) ---
WAVE_API_KEY=your-wave-api-key
WAVE_BUSINESS_ID=your-wave-business-id
# Endpoint: https://api.wave.com/v1/checkout/sessions

# --- ICAL SYNC ---
ICAL_SYNC_INTERVAL_MINUTES=5

# --- FRONTEND ---
FRONTEND_URL=http://localhost:5173

# --- CLAUDE AI (Assistant intégré) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
